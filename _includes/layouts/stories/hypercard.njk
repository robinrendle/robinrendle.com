<!DOCTYPE html>
<html class="no-js" lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Hypercard</title>
    <meta content="Robin Rendle" name="author" />
    <meta content="A website is a stack." name="description" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta name="fediverse:creator" content="@fonts@sfba.social">

    <link rel="icon" type="image/png" href="/images/favicons5/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/images/favicons5/favicon.svg" />
    <link rel="shortcut icon" href="/images/favicons5/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/favicons5/apple-touch-icon.png" />
    <link rel="manifest" href="/images/favicons5/site.webmanifest" />
    <style>

    @font-face {
      font-family: "MD UI";
      src: url("/fonts/md-ui/MDUI-VF-subset.woff2") format("woff2");
      font-style: oblique 0deg 12deg;
      font-weight: 200 900;
    }

    *,
    *:after,
    *:before {
      box-sizing: border-box;
    }

    html {
      -moz-text-size-adjust: none;
      -webkit-text-size-adjust: none;
      text-size-adjust: none;
      min-height: 100%;
      font-size: 100%;
      --font-sans:
        "MD UI", SF Pro Text, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
        Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji",
        "Segoe UI Symbol";
    }

    html, body {
      display: flex;
      margin: 0;
      padding: 0;
      height: 100dvh;
      background: gray;
    }

    body {
      font-family: var(--font-sans);
    }

    .container {
      display: flex;
      position: relative;
      flex-wrap: none;
      height: calc(100dvh - 45px);
      width: 100dvw;
      margin-left: calc(50% - 50dvw);
      overflow: hidden;
      gap: 20px;
      scroll-snap-type: x mandatory;
      margin-top: calc(var(--space-nav) * -1);
      height: 100dvh;
      background: rgba(255,255,255,.7);

      &:before {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        top: 0;
        content: "";
        height: 100dvh;
        width: 100%;
        opacity: 0.5;
        background-size: cover;
        background-repeat: no-repeat;
        background-image: url('/images/home-essay/pixel-background.webp');
      }
    }

    .card {
      --card-padding: 20px;
      position: relative;
      z-index: 2;
      padding: var(--card-padding);
      font-size: 1.5rem;
      line-height: 1.3;
      padding-right: 0;
      scroll-snap-align: start;
      height: calc(100dvh - 40px);
      max-height: 630px;
      margin: auto;
      min-width: calc(100dvw - var(--card-padding));
      flex-wrap: nowrap;
      display: flex;
      justify-content: center;

      @media screen and (min-width: 600px) {
        font-size: 1.625rem;
      }
    }

    .card c-window {
      max-width: 950px;
      height: 100%;
      width: 100%;
      text-align: center;
      display: flex;
    }

    .card .window-content {
      width: 100%;
      display: grid;
      place-content: center;
      gap: 30px;
      padding: 0 30px;
      text-wrap: balance;

      @media screen and (min-width: 600px) {
        padding: 0 60px;
      }
    }

    .card img {
      width: auto !important;
      max-width: 300px;
      max-height: 200px;
      margin: 0 auto;
      margin-top: -30px;
    }

    .container .card:last-of-type {
      padding-left: 0;
      padding-right: var(--card-padding);
    }

    .click-zone {
      position: fixed;
      top: 0;
      bottom: 0;
      width: 50%;
      z-index: 10;
    }

    #click-prev {
      left: 0;
      cursor: w-resize;
    }

    #click-next {
      right: 0;
      cursor: e-resize;
    }
    </style>
  </head>
  <body>
    <main>

      <div class="container">
        {{ content | safe }}
        <div class="click-zone" id="click-prev" aria-label="Previous"></div>
        <div class="click-zone" id="click-next" aria-label="Next"></div>
      </div>

      <script>
      let currentPosition = 0;
      const cardList = document.querySelectorAll('.card');

      function turnPageForward() {
        if (currentPosition < cardList.length - 1) {
          currentPosition = currentPosition + 1;
          cardList[currentPosition].scrollIntoView({ behavior: "instant", block: "center", inline: "nearest" });
        }
      }

      function turnPageBack() {
        if (currentPosition > 0) {
          currentPosition = currentPosition - 1;
          cardList[currentPosition].scrollIntoView({ behavior: "instant", block: "center", inline: "nearest" });
        }
      }

      document.querySelector('#click-prev').addEventListener('click', () => turnPageBack());
      document.querySelector('#click-next').addEventListener('click', () => turnPageForward());

      document.addEventListener("keydown", (e) => {
        if (e.keyCode === 37) {
          e.preventDefault();
          turnPageBack();
        }
        if (e.keyCode === 39 || e.keyCode === 32) {
          e.preventDefault();
          turnPageForward();
        }
      });
      </script>
    </main>
  </body>
</html>
